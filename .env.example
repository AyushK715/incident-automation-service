ES_HOST=https://elasticsearch.example.com:9243
ES_USER=your_es_user
ES_PASSWORD=your_es_password
ES_INDEX=alerts_index

APIGW_TOKEN_URL=https://auth.example.com/oauth2/access_token
APIGW_URL=https://apigw.example.com/gateway/api/arsys/v1/entry/INC_Incoming
APIGW_QUERY_URL=https://apigw.example.com/gateway/api/arsys/v1/entry/Retrieve_Inc_Details
APIGW_CLIENT_ID=your_client_id
APIGW_CLIENT_SECRET=your_client_secret
APIGW_OAUTH_SCOPE=default

ENVIRONMENT_NAME=ENV-PREPROD
CLUSTER_UUID=

MAX_RETRIES=8
RETRY_DELAY_SECONDS=900
RETRY_DELAY_TSM_SECONDS=480
ALERT_CUTOFF_HOURS=48
POLL_INTERVAL_SECONDS=60
BATCH_SIZE=100
